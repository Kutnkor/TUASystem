def donki_verisi_cek(olay_tipi: str, baslangic_tarihi: str, bitis_tarihi: str) -> List[Dict[str, Any]]:
    url = f"{TEMEL_URL}/{olay_tipi}"
    parametreler = {
        "startDate": baslangic_tarihi,
        "endDate": bitis_tarihi,
        "api_key": API_ANAHTARI
    }

    try:
        cevap = requests.get(url, params=parametreler, timeout=20)
        cevap.raise_for_status()
        veri = cevap.json()
        return veri if isinstance(veri, list) else []
    except requests.RequestException as hata:
        raise RuntimeError(f"{olay_tipi} verisi alınamadı: {hata}") from hata
    except ValueError as hata:
        raise RuntimeError(f"{olay_tipi} verisi çözümlenemedi: {hata}") from hata


def gunes_patlamasi_skoru_hesapla(gunes_patlamalari: List[Dict[str, Any]]) -> float:
    toplam_skor = 0.0

    for olay in gunes_patlamalari:
        sinif_tipi = olay.get("classType", "")
        if not sinif_tipi:
            continue

        try:
            patlama_sinifi = sinif_tipi[0].upper()
            buyukluk = float(sinif_tipi[1:]) if len(sinif_tipi) > 1 else 1.0
        except (ValueError, IndexError):
            continue

        if patlama_sinifi == "C":
            toplam_skor += 1.0 * buyukluk
        elif patlama_sinifi == "M":
            toplam_skor += 5.0 * buyukluk
        elif patlama_sinifi == "X":
            toplam_skor += 12.0 * buyukluk

    return toplam_skor


def koronal_kutle_atimi_skoru_hesapla(koronal_kutle_atimlari: List[Dict[str, Any]]) -> float:
    toplam_skor = 0.0

    for olay in koronal_kutle_atimlari:
        analizler = olay.get("cmeAnalyses", [])

        if not analizler:
            toplam_skor += 3.0
            continue

        en_yuksek_hiz_skoru = 0.0

        for analiz in analizler:
            hiz = analiz.get("speed")

            if isinstance(hiz, (int, float)):
                if hiz < 500:
                    skor = 2.0
                elif hiz < 1000:
                    skor = 5.0
                elif hiz < 2000:
                    skor = 9.0
                elif hiz < 3000:
                    skor = 14.0
                elif hiz < 4000:
                    skor = 20.0
                else:
                    skor = 28.0

                en_yuksek_hiz_skoru = max(en_yuksek_hiz_skoru, skor)

        toplam_skor += en_yuksek_hiz_skoru if en_yuksek_hiz_skoru > 0 else 3.0

    return toplam_skor


def enerjik_parcacik_skoru_hesapla(enerjik_parcacik_olaylari: List[Dict[str, Any]]) -> float:
    toplam_skor = 0.0

    for olay in enerjik_parcacik_olaylari:
        cihazlar = olay.get("instruments", [])
        temel_skor = 10.0

        if len(cihazlar) >= 2:
            temel_skor += 2.0
        if len(cihazlar) >= 4:
            temel_skor += 6.0
        if len(cihazlar) >= 5:
            temel_skor += 10.0

        toplam_skor += temel_skor

    return toplam_skor


