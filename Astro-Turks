        zaman = datetime.now(UTC).strftime("%H:%M:%S")
        self.olay_gunlugu.configure(state="normal")
        self.olay_gunlugu.insert("end", f"[{zaman}] {mesaj}\n")
        self.olay_gunlugu.see("end")
        self.olay_gunlugu.configure(state="disabled")

    def _kart_olustur(self, ebeveyn, baslik: str):
        dis_cerceve = tk.Frame(
            ebeveyn,
            bg="#1e293b",
            bd=0,
            highlightthickness=0,
            padx=8,
            pady=8
        )

        baslik_etiketi = tk.Label(
            dis_cerceve,
            text=baslik,
            font=("Arial", 9, "bold"),
            bg="#1e293b",
            fg="white",
            justify="left",
            wraplength=200,
            anchor="w"
        )
        baslik_etiketi.pack(anchor="w", fill="x")

        deger_etiketi = tk.Label(
            dis_cerceve,
            text="-",
            font=("Arial", 16, "bold"),
            bg="#334155",
            fg="black",
            width=20,
            height=4,
            justify="center",
            wraplength=200
        )
        deger_etiketi.pack(fill="both", expand=True, pady=(8, 0))

        return dis_cerceve, deger_etiketi

    def _arayuzu_kur(self):
        ana = tk.Frame(self.pencere, bg="#0f172a")
        ana.pack(fill="both", expand=True, padx=14, pady=14)
        self.ana_panel = ana

        ana.grid_columnconfigure(0, weight=3)
        ana.grid_columnconfigure(1, weight=2)
        ana.grid_rowconfigure(1, weight=2)
        ana.grid_rowconfigure(2, weight=2)
        ana.grid_rowconfigure(3, weight=1)

        ust = tk.Frame(ana, bg="#1e293b", padx=10, pady=10)
