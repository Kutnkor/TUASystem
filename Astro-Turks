def kisa_vadeli_tahmin_yap(risk_gecmisi: List[float]) -> str:
    if len(risk_gecmisi) < 3:
        return "Yetersiz veri"

    son = risk_gecmisi[-1]
    onceki = risk_gecmisi[-3]
    fark = son - onceki

    if fark > 8:
        return "Risk hızla artıyor"
    elif fark > 2:
        return "Risk artış eğiliminde"
    elif fark < -8:
        return "Risk hızla düşüyor"
    elif fark < -2:
        return "Risk düşüş eğiliminde"
    return "Risk kararlı"


def karar_guveni_hesapla(toplam_risk: float, simulasyon_aktif: bool) -> float:
    temel = min(92.0, 45.0 + toplam_risk * 1.2)
    if simulasyon_aktif:
        temel -= 6.0
    return max(35.0, min(95.0, temel))


