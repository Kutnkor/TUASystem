    def verileri_yenile(self, otomatik: bool = False) -> None:
        try:
            if otomatik:
                self.olay_gunlugune_ekle("Canlı grafik için otomatik veri yenileme başlatıldı.")
            else:
                self.olay_gunlugune_ekle("Veri yenileme başlatıldı.")

            if self.simulasyon_modu_acik:
                senaryo = simule_storm_senaryosu(self.simulasyon_seviyesi)

                gunes_patlamasi_verileri = senaryo["flr"]
                koronal_kutle_atimi_verileri = senaryo["cme"]
                enerjik_parcacik_verileri = senaryo["sep"]

                self.ust_bilgi_metin.set(f"Simulation Mode | {senaryo['senaryo_adi']}")
                self.simulasyon_seviyesi_metin.set(
                    f"Simülasyon Senaryosu: {senaryo['senaryo_adi']}"
                )
                self.olay_gunlugune_ekle(
                    f"Simülasyon verisi üretildi: {senaryo['senaryo_adi']} | {senaryo['aciklama']}"
                )
            else:
                bugun = datetime.now(UTC).date()
                yedi_gun_once = bugun - timedelta(days=7)

                baslangic = yedi_gun_once.isoformat()
                bitis = bugun.isoformat()

                self.ust_bilgi_metin.set(f"Son 7 Gün Verisi | {baslangic} → {bitis}")
                self.simulasyon_seviyesi_metin.set("Simülasyon Senaryosu: Gerçek Veri")
                self.olay_gunlugune_ekle("Tarih aralığı hazırlandı.")

                gunes_patlamasi_verileri = donki_verisi_cek("FLR", baslangic, bitis)
                koronal_kutle_atimi_verileri = donki_verisi_cek("CME", baslangic, bitis)
                enerjik_parcacik_verileri = donki_verisi_cek("SEP", baslangic, bitis)

            gunes_olay_sayisi = len(gunes_patlamasi_verileri)
            cme_olay_sayisi = len(koronal_kutle_atimi_verileri)
            sep_olay_sayisi = len(enerjik_parcacik_verileri)

            self.olay_gunlugune_ekle(f"Güneş Patlaması verisi işlendi. Olay sayısı: {gunes_olay_sayisi}")
            self.olay_gunlugune_ekle(f"Koronal Kütle Atımı verisi işlendi. Olay sayısı: {cme_olay_sayisi}")
            self.olay_gunlugune_ekle(f"Enerjik Parçacık verisi işlendi. Olay sayısı: {sep_olay_sayisi}")

            gunes_patlamasi_skoru = gunes_patlamasi_skoru_hesapla(gunes_patlamasi_verileri)
            koronal_kutle_atimi_skoru = koronal_kutle_atimi_skoru_hesapla(koronal_kutle_atimi_verileri)
            enerjik_parcacik_skoru = enerjik_parcacik_skoru_hesapla(enerjik_parcacik_verileri)

            toplam_risk_skoru = (
                1.2 * gunes_patlamasi_skoru +
                1.5 * koronal_kutle_atimi_skoru +
                2.0 * enerjik_parcacik_skoru
            )

            self.risk_gecmisi.append(toplam_risk_skoru)
            self.zaman_gecmisi.append(datetime.now(UTC).strftime("%H:%M:%S"))

            if len(self.risk_gecmisi) > 10:
                self.risk_gecmisi.pop(0)
                self.zaman_gecmisi.pop(0)

            risk_seviyesi = risk_seviyesi_belirle(toplam_risk_skoru)
            risk_aciklamasi = risk_seviyesi_aciklamasi(risk_seviyesi)
            operasyon_mesaji = operasyon_mesaji_olustur(risk_seviyesi)

            if risk_seviyesi == "NORMAL":
                risk_seviyesi_sayisal = 1
                trend_metni = "Kararlı"
            elif risk_seviyesi == "UYARI":
                risk_seviyesi_sayisal = 2
                trend_metni = "Yükseliş"
            else:
                risk_seviyesi_sayisal = 3
                trend_metni = "Kritik"

            tahmin = kisa_vadeli_tahmin_yap(self.risk_gecmisi)
            karar_guveni = karar_guveni_hesapla(toplam_risk_skoru, self.simulasyon_modu_acik)
            onerilen_aksiyon = onerilen_aksiyon_olustur(
                risk_seviyesi,
                simulasyon_aktif=self.simulasyon_modu_acik,
                simulasyon_seviyesi=self.simulasyon_seviyesi
            )

            uydu_tepki_plani = uydu_tepki_plani_olustur(
                risk_seviyesi,
                simulasyon_aktif=self.simulasyon_modu_acik,
                simulasyon_seviyesi=self.simulasyon_seviyesi
            )

            self.olay_gunlugune_ekle("Risk skorları hesaplandı.")
            self.olay_gunlugune_ekle(
                f"Ağırlıklı toplam risk skoru: {toplam_risk_skoru:.2f} | "
                f"Formül = 1.2×FLR + 1.5×CME + 2.0×SEP"
            )
            self.olay_gunlugune_ekle(
                f"Risk seviyesi belirlendi: {risk_seviyesi} ({risk_seviyesi_sayisal})"
            )
            self.olay_gunlugune_ekle(f"Karar motoru çıktısı: {operasyon_mesaji}")
            self.olay_gunlugune_ekle(f"Trend analizi: {trend_metni}")
            self.olay_gunlugune_ekle(f"Tahmin motoru: {tahmin}")
            self.olay_gunlugune_ekle(f"Karar güven skoru: %{karar_guveni:.0f}")
            self.olay_gunlugune_ekle(onerilen_aksiyon)

            if self.simulasyon_modu_acik and self.simulasyon_seviyesi >= 4:
                self.olay_gunlugune_ekle("!!! AŞIRI SENARYO: Tüm görev dışı yükler kapatıldı.")
                self.olay_gunlugune_ekle("!!! AŞIRI SENARYO: Uydu yalnızca hayatta kalma protokolleriyle çalışıyor.")

            self.toplam_risk_metin.set(f"Toplam Radyasyon Riski: {toplam_risk_skoru:.2f}")
            self.risk_seviyesi_metin.set(f"Operasyon Durumu: {risk_aciklamasi} / {risk_seviyesi}")
            self.trend_metin.set(f"Trend Analizi: {trend_metni}")
            self.tahmin_metin.set(f"Kısa Vadeli Tahmin: {tahmin}")
            self.karar_guven_metin.set(f"Karar Güveni: %{karar_guveni:.0f}")
            self.onerilen_aksiyon_metin.set(onerilen_aksiyon)
            self.son_guncelleme_metin.set(
                "Son Güncelleme: " + datetime.now(UTC).strftime("%d.%m.%Y %H:%M:%S UTC")
            )

            self.alarm_gorselini_guncelle(risk_seviyesi)

            self.kartlar["gunes_patlamasi"].configure(
                text=f"Risk Skoru: {gunes_patlamasi_skoru:.1f}",
                bg=kutu_rengi_skor(gunes_patlamasi_skoru, "gunes_patlamasi")
            )
            self.kartlar["koronal_kutle_atimi"].configure(
                text=f"Risk Skoru: {koronal_kutle_atimi_skoru:.1f}",
                bg=kutu_rengi_skor(koronal_kutle_atimi_skoru, "koronal_kutle_atimi")
            )
            self.kartlar["enerjik_parcacik"].configure(
                text=f"Risk Skoru: {enerjik_parcacik_skoru:.1f}",
                bg=kutu_rengi_skor(enerjik_parcacik_skoru, "enerjik_parcacik")
            )
            self.kartlar["genel"].configure(
                text=f"Toplam Risk: {toplam_risk_skoru:.1f}",
                bg=kutu_rengi_skor(toplam_risk_skoru, "genel")
            )
            self.kartlar["risk_seviyesi"].configure(
                text=f"Durum: {risk_seviyesi}\nSeviye: {risk_seviyesi_sayisal}",
                bg="#ddd6fe" if risk_seviyesi == "NORMAL" else "#fde68a" if risk_seviyesi == "UYARI" else "#fecaca"
            )
            self.kartlar["flr_olay"].configure(
                text=f"Tespit Edilen Olay: {gunes_olay_sayisi}",
                bg="#bfdbfe"
            )
            self.kartlar["cme_olay"].configure(
                text=f"Tespit Edilen Olay: {cme_olay_sayisi}",
                bg="#fed7aa"
            )
            self.kartlar["sep_olay"].configure(
                text=f"Tespit Edilen Olay: {sep_olay_sayisi}",
                bg="#bbf7d0"
            )

            for alan, deger in uydu_tepki_plani.items():
                renk = "white"
                if risk_seviyesi == "UYARI":
                    renk = "#fde68a"
                elif risk_seviyesi == "GÜVENLİ MOD":
                    renk = "#fca5a5"

                self.tepki_etiketleri[alan].configure(
                    text=deger,
                    fg=renk
                )

            self.grafigi_guncelle(
                gunes_patlamasi_skoru,
                koronal_kutle_atimi_skoru,
                enerjik_parcacik_skoru,
                toplam_risk_skoru,
                risk_seviyesi_sayisal,
                gunes_olay_sayisi,
                cme_olay_sayisi,
                sep_olay_sayisi
            )

            self.olay_gunlugune_ekle("Kareli sütun grafiği güncellendi.")
            self.olay_gunlugune_ekle("Üst kartlardaki tüm metrikler güncellendi.")
            self.olay_gunlugune_ekle("Uydu tepki planındaki donanım durumları güncellendi.")
            self.olay_gunlugune_ekle("Arayüz başarıyla yenilendi.")
            self.olay_gunlugune_ekle("-" * 60)

        except Exception as hata:
            self.olay_gunlugune_ekle(f"HATA: {hata}")
            messagebox.showerror("Hata", str(hata))


