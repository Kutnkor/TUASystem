def kutu_rengi_skor(skor: float, olay_tipi: str) -> str:
    if olay_tipi == "genel":
        if skor < 10:
            return "#b9f6ca"
        elif skor < 25:
            return "#fff59d"
        return "#ff8a80"

    if olay_tipi == "gunes_patlamasi":
        if skor < 5:
            return "#b9f6ca"
        elif skor < 15:
            return "#fff59d"
        return "#ff8a80"

    if olay_tipi == "koronal_kutle_atimi":
        if skor < 5:
            return "#b9f6ca"
        elif skor < 10:
            return "#fff59d"
        return "#ff8a80"

    if olay_tipi == "enerjik_parcacik":
        if skor < 10:
            return "#b9f6ca"
        elif skor < 20:
            return "#fff59d"
        return "#ff8a80"

    return "#e0e0e0"


def simule_flr_verisi(seviye: int) -> List[Dict[str, Any]]:
    if seviye == 1:
        secenekler = ["C4.8", "M1.2", "M2.3"]
        adet = random.randint(1, 3)
    elif seviye == 2:
        secenekler = ["M3.5", "M5.8", "X1.1", "X1.4"]
        adet = random.randint(2, 4)
    elif seviye == 3:
        secenekler = ["X2.5", "X4.1", "X6.3", "X9.0"]
        adet = random.randint(3, 6)
    elif seviye == 4:
        secenekler = ["X10.0", "X12.5", "X15.0"]
        adet = random.randint(4, 7)
    else:
        secenekler = ["X20.0", "X25.0", "X30.0"]
        adet = random.randint(6, 10)

    return [{"classType": random.choice(secenekler)} for _ in range(adet)]


def simule_cme_verisi(seviye: int) -> List[Dict[str, Any]]:
    if seviye == 1:
        hiz_araligi = (500, 900)
        adet = random.randint(1, 2)
    elif seviye == 2:
        hiz_araligi = (1000, 1800)
        adet = random.randint(2, 4)
    elif seviye == 3:
        hiz_araligi = (1800, 2800)
        adet = random.randint(3, 5)
    elif seviye == 4:
        hiz_araligi = (2500, 3500)
        adet = random.randint(4, 6)
    else:
        hiz_araligi = (3500, 5000)
        adet = random.randint(5, 8)

    veriler = []
    for _ in range(adet):
        hiz = round(random.uniform(*hiz_araligi), 1)
        veriler.append({
            "cmeAnalyses": [{"speed": hiz}]
        })
    return veriler


def simule_sep_verisi(seviye: int) -> List[Dict[str, Any]]:
    if seviye == 1:
        adet = random.randint(0, 1)
        cihaz_sayisi = [1, 2]
    elif seviye == 2:
        adet = random.randint(1, 3)
        cihaz_sayisi = [2, 3]
    elif seviye == 3:
        adet = random.randint(3, 5)
        cihaz_sayisi = [3, 4]
    elif seviye == 4:
        adet = random.randint(4, 6)
        cihaz_sayisi = [4, 5]
    else:
        adet = random.randint(6, 9)
        cihaz_sayisi = [5, 6]

    veriler = []
    for _ in range(adet):
        sayi = random.choice(cihaz_sayisi)
        veriler.append({
            "instruments": [{"displayName": f"SIM-{i+1}"} for i in range(sayi)]
        })
    return veriler


def simule_storm_senaryosu(seviye: int) -> Dict[str, Any]:
    flr = simule_flr_verisi(seviye)
