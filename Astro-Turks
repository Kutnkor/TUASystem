    def simulasyon_seviyesi_degistir(self) -> None:
        self.simulasyon_seviyesi += 1

        if self.simulasyon_seviyesi > self.maksimum_simulasyon_seviyesi:
            self.simulasyon_seviyesi = 1

        self.storm_dugmesi.configure(text=f"Storm Seviyesi: L{self.simulasyon_seviyesi}")

        self.olay_gunlugune_ekle(
            f"Simülasyon seviyesi L{self.simulasyon_seviyesi} olarak ayarlandı."
        )

        if self.simulasyon_modu_acik:
            self.olay_gunlugune_ekle(
                "Yeni simülasyon seviyesi için veriler ve uydu tepki planı yenileniyor."
            )
            self.verileri_yenile(otomatik=False)

    def simulasyon_modunu_degistir(self) -> None:
        self.simulasyon_modu_acik = not self.simulasyon_modu_acik

        if self.simulasyon_modu_acik:
            self.simulasyon_metin.set("Simulation Mode: Açık")
            self.olay_gunlugune_ekle("Simulation Mode açıldı.")
            self.olay_gunlugune_ekle(
                f"L{self.simulasyon_seviyesi} senaryosu ile sentetik uzay hava durumu üretilecek."
            )
        else:
            self.simulasyon_metin.set("Simulation Mode: Kapalı")
            self.simulasyon_seviyesi_metin.set("Simülasyon Senaryosu: Gerçek Veri")
            self.olay_gunlugune_ekle("Simulation Mode kapatıldı.")

        self.verileri_yenile(otomatik=False)

    def alarm_gorselini_guncelle(self, risk_seviyesi: str) -> None:
        if risk_seviyesi == "NORMAL":
            self.ust_panel.configure(bg="#1e293b")
            self.karar_motoru_metin.set("OTONOM KARAR: NORMAL GÖREV OPERASYONU")
        elif risk_seviyesi == "UYARI":
            self.ust_panel.configure(bg="#1e293b")
            self.karar_motoru_metin.set("⚠ OTONOM KARAR: KORUMALI OPERASYON AKTİF")
        else:
            self.ust_panel.configure(bg="#0f172a")

            if self.alarm_durumu_acik:
                self.karar_motoru_metin.set("🚨 KRİTİK ALARM: GÜVENLİ MOD AKTİF")
            else:
                self.karar_motoru_metin.set("⛔ KRİTİK RİSK: ACİL KORUMA DEVREDE")

            self.alarm_durumu_acik = not self.alarm_durumu_acik

    def loglari_kaydet(self) -> None:
        try:
            zaman_damgasi = datetime.now(UTC).strftime("%Y%m%d_%H%M%S")
            dosya_adi = f"astro_turks_log_{zaman_damgasi}.txt"

            icerik = self.olay_gunlugu.get("1.0", "end-1c")

            with open(dosya_adi, "w", encoding="utf-8") as dosya:
                dosya.write("ASTRO TURKS | Görev Logu\n")
                dosya.write("=" * 60 + "\n")
                dosya.write(self.toplam_risk_metin.get() + "\n")
                dosya.write(self.risk_seviyesi_metin.get() + "\n")
                dosya.write(self.trend_metin.get() + "\n")
                dosya.write(self.tahmin_metin.get() + "\n")
                dosya.write(self.karar_guven_metin.get() + "\n")
                dosya.write(self.simulasyon_seviyesi_metin.get() + "\n")
                dosya.write(self.onerilen_aksiyon_metin.get() + "\n")
                dosya.write("=" * 60 + "\n\n")
                dosya.write(icerik)

            self.olay_gunlugune_ekle(f"Log dosyası kaydedildi: {dosya_adi}")
            messagebox.showinfo("Başarılı", f"Log dosyası kaydedildi:\n{dosya_adi}")

        except Exception as hata:
            self.olay_gunlugune_ekle(f"Log kaydetme hatası: {hata}")
            messagebox.showerror("Hata", f"Log kaydedilemedi:\n{hata}")

    def grafigi_guncelle(
        self,
        gunes_patlamasi_skoru: float,
        koronal_kutle_atimi_skoru: float,
        enerjik_parcacik_skoru: float,
        toplam_risk: float,
        risk_seviyesi_sayisal: int,
        gunes_olay_sayisi: int,
        cme_olay_sayisi: int,
        sep_olay_sayisi: int
    ) -> None:
        self.eksen.clear()

        kategoriler = [
            "FLR\nRisk",
            "CME\nRisk",
            "SEP\nRisk",
            "Toplam\nRisk",
            "Risk\nSeviyesi",
            "FLR\nOlay",
            "CME\nOlay",
            "SEP\nOlay"
        ]

        degerler = [
            gunes_patlamasi_skoru,
            koronal_kutle_atimi_skoru,
            enerjik_parcacik_skoru,
            toplam_risk,
            risk_seviyesi_sayisal,
            gunes_olay_sayisi,
            cme_olay_sayisi,
            sep_olay_sayisi
        ]

        renkler = [
            "#60a5fa",
            "#f97316",
            "#22c55e",
            "#ef4444" if toplam_risk >= 25 else "#facc15" if toplam_risk >= 10 else "#38bdf8",
            "#a855f7",
            "#93c5fd",
            "#fdba74",
            "#86efac"
        ]

        cubuklar = self.eksen.bar(kategoriler, degerler, color=renkler, width=0.62)

        self.eksen.set_title("Uzay Hava Durumu Tabanlı Radyasyon Risk Analizi", color="white", fontsize=9)
        self.eksen.set_ylabel("Risk Skoru / Olay Sayısı / Seviye", color="white", fontsize=7)

        self.eksen.tick_params(axis="x", colors="white", labelrotation=0, labelsize=6)
        self.eksen.tick_params(axis="y", colors="white", labelsize=6)

        self.eksen.spines["bottom"].set_color("white")
        self.eksen.spines["left"].set_color("white")
        self.eksen.spines["top"].set_color("white")
        self.eksen.spines["right"].set_color("white")

        self.eksen.grid(True, axis="y", color="#475569", alpha=0.35, linestyle="-")
        self.eksen.set_axisbelow(True)

        for cubuk, deger in zip(cubuklar, degerler):
            self.eksen.text(
                cubuk.get_x() + cubuk.get_width() / 2,
                cubuk.get_height() + 0.8,
                f"{deger:.1f}",
                ha="center",
                va="bottom",
                fontsize=5,
                color="white",
                fontweight="bold"
            )

        self.fig.tight_layout()
        self.canvas.draw()

